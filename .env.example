# ============================================================
# miCompaWeb v1.2 - Variables de Entorno
# Copiar a: .env y rellenar con tus valores reales
# ============================================================

# --- APIs EXTERNAS (requeridas para modo real) ---

# Google Places API (New)
# Obtener en: https://developers.google.com/maps/documentation/places/web-service
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Groq API (LLM cloud - barato y rapido)
# Obtener en: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter (alternativa a Groq - opcional)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- CONFIGURACION LLM ---

# Proveedor por defecto: groq | ollama | heuristic
DEFAULT_LLM_PROVIDER=groq

# Ollama (LLM local - gratuito)
# Requiere Ollama instalado: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
# En Docker Compose: OLLAMA_BASE_URL=http://ollama:11434

# --- M2: VECTOR SEARCH + ANTI-BOT ---

# Qdrant Vector Database
# Local (sin Docker): QDRANT_URL=http://localhost:6333
# Docker Compose: QDRANT_URL=http://qdrant:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                    # Dejar vacio para Qdrant local sin auth

# SearXNG Meta-buscador (SERP propia)
# Local (sin Docker): SEARXNG_URL=http://localhost:8080
# Docker Compose: SEARXNG_URL=http://searxng:8080
SEARXNG_URL=http://localhost:8080

# FastEmbed: Modelo de embeddings local
# Opciones: BAAI/bge-small-en-v1.5 (default), BAAI/bge-base-en-v1.5
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Crawl4AI / Anti-bot configuracion
# Numero maximo de paginas a extraer por dominio
MAX_PAGES_PER_DOMAIN=10
# Delay entre requests (ms)
REQUEST_DELAY_MS=1000
# User-agent rotativo
ROTATE_USER_AGENTS=true

# --- CONTROL DE COSTOS ---

# Maximo gasto diario en APIs (USD) - limite de seguridad
MAX_DAILY_COST_USD=2.00

# Habilitar tracking de costos
ENABLE_COST_TRACKING=true

# --- DIRECTORIOS ---

CACHE_DIR=./projects/.cache
PROJECTS_DIR=./projects

# --- FEATURE FLAGS ---

# Verificar vigencia de contenido web (M2 anti-bot)
ENABLE_VIGENCY_CHECK=true

# Sincronizacion con NocoDB
ENABLE_NOCODB_SYNC=false

# Habilitar modo anti-bot avanzado (TLS spoofing, etc.)
ENABLE_ANTI_BOT=true

# Usar cache distribuida (Redis) en lugar de SQLite
ENABLE_REDIS_CACHE=false

# --- LOGGING ---

# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Formato: console | json
LOG_FORMAT=console

# --- PRODUCCION ---

# Modo produccion (desactiva wizard interactivo, usa batch)
PRODUCTION_MODE=false

# Numero de workers para procesamiento paralelo
WORKER_COUNT=4

# Timeout por operacion de scraping (segundos)
SCRAPING_TIMEOUT_SECONDS=30
